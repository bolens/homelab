# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
PUID=1000
PGID=1000

# VERSION should usually be "docker"
VERSION=docker

# Optional: Plex claim token (only needed on first run to link your server)
# Obtain from https://www.plex.tv/claim and paste here, then remove after the server is claimed.
# PLEX_CLAIM=REPLACE_WITH_PLEX_CLAIM_TOKEN

