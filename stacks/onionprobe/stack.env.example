# Onionprobe – copy to stack.env and adjust if needed.
# See upstream: https://gitlab.torproject.org/tpo/onion-services/onionprobe/-/blob/main/configs/env.sample

# Optional: Grafana Postgres password (default change-me-in-production).
# Use a strong random password here, for example:
#   openssl rand -hex 32
# GRAFANA_DATABASE_PASSWORD=

# Optional: URL users use to reach Grafana (for redirects, links). No trailing slash.
# GF_SERVER_ROOT_URL=https://onionprobe.home

# Optional: Prometheus external URL (for links in Prometheus UI)
# PROMETHEUS_WEB_EXTERNAL_URL=http://op-prometheus:9090

# Optional: configurator/build user (match host UID/GID if you hit permission issues)
# CONTAINER_UID=1000
# CONTAINER_GID=1000

# Optional: custom Onionprobe config path inside the repo (default contrib/tpo.yaml)
# ONIONPROBE_CONFIG=contrib/tpo.yaml

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
