# Navidrome – copy to stack.env. Optional: set TZ and ND_* options.
#
# See documents/ENV-VARS.md and Navidrome configuration options:
#   https://navidrome.org/docs/usage/configuration/options/
#

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# -----------------------------------------------------------------------------
# Navidrome options (all optional)
# -----------------------------------------------------------------------------

# Base URL when running behind a reverse proxy. Use your full Navidrome URL,
# for example: https://music.yourdomain.com
# ND_BASEURL=

# Log level: trace, debug, info, warn, error
# ND_LOGLEVEL=info

# Library rescan schedule (cron-style or duration, e.g. 1h, 24h)
# ND_SCANSCHEDULE=1h

