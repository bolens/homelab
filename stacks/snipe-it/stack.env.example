# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Snipe-IT application settings (see official docs for full list)
APP_URL=https://snipe-it.yourdomain.com
APP_KEY=REPLACE_WITH_GENERATED_APP_KEY
APP_TIMEZONE=America/Denver
APP_LOCALE=en
APP_ENV=production

# Database settings (match snipeit-db service)
DB_CONNECTION=mysql
DB_HOST=snipe-it-db
DB_DATABASE=snipeit
DB_USERNAME=snipeit
DB_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# Mail settings (use shared postfix SMTP relay – stacks/postfix)
MAIL_DRIVER=smtp
MAIL_HOST=smtp-relay
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDR=snipe-it@yourdomain.com
MAIL_FROM_NAME="Snipe-IT"

