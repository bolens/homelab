# Timezone and file ownership (LinuxServer.io image)
TZ=America/Denver
PUID=1000
PGID=1000

# --- Gluetun VPN (required) ---
# Set your VPN provider. Examples: "custom" (WireGuard conf), "mullvad", "nordvpn", "protonvpn", etc.
# See https://gluetun.com/configuration/ and https://github.com/qdm12/gluetun-wiki
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard

# Custom WireGuard (when VPN_SERVICE_PROVIDER=custom). Replace with your VPN provider's values.
# Get endpoint IP (resolve your provider's hostname), port, keys, and assigned address from the provider.
# WIREGUARD_PRIVATE_KEY=REPLACE_WITH_YOUR_PRIVATE_KEY
# WIREGUARD_ADDRESSES=10.64.x.x/32
# WIREGUARD_ENDPOINT_IP=1.2.3.4
# WIREGUARD_ENDPOINT_PORT=51820
# WIREGUARD_PUBLIC_KEY=REPLACE_WITH_SERVER_PUBLIC_KEY

# Optional: preshared key if your provider uses one
# WIREGUARD_PRESHARED_KEY=

# --- qBittorrent Web UI (optional) ---
# Default is 8080; leave unset when behind Gluetun (port 8080 is used internally).
# WEBUI_PORT=8080
