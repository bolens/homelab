# Ollama Configuration
# Copy this file to .env and customize as needed

# Host port for Ollama API (default: 11434)
OLLAMA_HOST_PORT=11434

# Path to store Ollama models on host (absolute path recommended)
# Example: /home/user/ollama-models or /mnt/storage/ollama-models
OLLAMA_MODELS_PATH=./models

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
