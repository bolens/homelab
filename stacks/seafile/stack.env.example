# Seafile – self-hosted file sync and sharing
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Seafile: https://www.seafile.com/
# - Docker: https://manual.seafile.com/docker/

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------

# Root password for MariaDB (required).
# Generate with: openssl rand -base64 24
MYSQL_ROOT_PASSWORD=REPLACE_WITH_GENERATED_ROOT_PASSWORD

# Seafile DB credentials.
SEAFILE_DB_NAME=seafile
SEAFILE_DB_USER=seafile
# Generate with: openssl rand -base64 24
SEAFILE_DB_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Seafile server
# -----------------------------------------------------------------------------

# Public hostname used by Seafile (must match your Caddy URL).
# Example: seafile.yourdomain.com
SEAFILE_SERVER_HOSTNAME=seafile.yourdomain.com

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

