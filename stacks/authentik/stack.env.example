# authentik – identity provider / SSO
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://goauthentik.io/
# - Installation: https://goauthentik.io/docs/installation/docker-compose

# -----------------------------------------------------------------------------
# Core secrets
# -----------------------------------------------------------------------------

# Secret key used by authentik (required).
# Generate with: openssl rand -base64 50
AUTHENTIK_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Database connection for authentik.
# PG_DB / PG_USER / PG_PASS are used in docker-compose.yml for the Postgres service.
PG_DB=authentik
PG_USER=authentik
# Generate with: openssl rand -base64 24
PG_PASS=REPLACE_WITH_GENERATED_DB_PASSWORD

# These are read by the server/worker via AUTHENTIK_POSTGRESQL__* vars.
# Use the same values as PG_DB / PG_USER / PG_PASS above.
AUTHENTIK_POSTGRESQL__HOST=postgres
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

AUTHENTIK_REDIS__HOST=redis
AUTHENTIK_REDIS__PORT=6379

# -----------------------------------------------------------------------------
# Host / URL
# -----------------------------------------------------------------------------

# Public URL for authentik when running behind Caddy.
# Example: https://authentik.yourdomain.com
AUTHENTIK_HOST=https://authentik.yourdomain.com

# Optional timezone
TZ=America/Denver

