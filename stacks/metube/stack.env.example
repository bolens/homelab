# MeTube – optional environment variables
#
# Copy to stack.env and edit values as needed.
# Upstream docs: https://github.com/alexta69/metube

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: run MeTube as a specific user/group (matches host UID/GID for
# file ownership on the mounted volume).
# PUID=1000
# PGID=1000
# UMASK=022

# -----------------------------------------------------------------------------
# Download behaviour
# -----------------------------------------------------------------------------

# Maximum number of simultaneous downloads. Default: 3
# MAX_CONCURRENT_DOWNLOADS=3

# If true, delete downloaded files from disk when trashing them in the UI.
# Default: false
# DELETE_FILE_ON_TRASHCAN=false

# Maximum number of playlist items to download. 0 = no limit. Default: 0
# DEFAULT_OPTION_PLAYLIST_ITEM_LIMIT=0

# -----------------------------------------------------------------------------
# Storage & directories (inside the container)
# -----------------------------------------------------------------------------

# Main download directory (mapped from the host in docker-compose).
# Defaults to /downloads.
# DOWNLOAD_DIR=/downloads

# Optional separate directory for audio-only downloads. Defaults to DOWNLOAD_DIR.
# AUDIO_DOWNLOAD_DIR=/downloads/audio

# Where to persist queue/state files. Defaults to /downloads/.metube.
# STATE_DIR=/downloads/.metube

# Where to store temporary files. Defaults to /downloads.
# TEMP_DIR=/downloads/tmp

# If true, allow choosing subdirectories under DOWNLOAD_DIR/AUDIO_DOWNLOAD_DIR.
# CUSTOM_DIRS=true

# If true, automatically create custom directories that don't exist yet.
# CREATE_CUSTOM_DIRS=true

# If true, make download directories indexable from the web server. Default: false
# DOWNLOAD_DIRS_INDEXABLE=false

# -----------------------------------------------------------------------------
# Web server & URLs
# -----------------------------------------------------------------------------

# Host and port MeTube binds to inside the container.
# HOST=0.0.0.0
# PORT=8081

# Base path when hosted behind a reverse proxy on a sub-path. Default: /
# URL_PREFIX=/

# Base URL for download links in the UI. By default, MeTube serves downloads
# from its own URL. Set this if your downloads live under a different origin.
# PUBLIC_HOST_URL=
# PUBLIC_HOST_AUDIO_URL=

# -----------------------------------------------------------------------------
# UI & logging
# -----------------------------------------------------------------------------

# Default theme: light, dark, or auto. Default: auto
# DEFAULT_THEME=auto

# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL, or NONE. Default: INFO
# LOGLEVEL=INFO

# Enable HTTP access log. Default: false
# ENABLE_ACCESSLOG=false

# -----------------------------------------------------------------------------
# Advanced yt-dlp options
# -----------------------------------------------------------------------------

# Additional options passed to yt-dlp in JSON format.
# Example (SANITIZED):
# YTDL_OPTIONS={"format":"best","retries":10}
#
# For cookie-based downloads:
#   1. Mount a host directory with cookies.txt to /cookies in docker-compose.
#   2. Uncomment the line below:
# YTDL_OPTIONS={"cookiefile":"/cookies/cookies.txt"}
#
# YTDL_OPTIONS=

# Path to a JSON file with yt-dlp options. If both are set, YTDL_OPTIONS wins.
# YTDL_OPTIONS_FILE=/downloads/ytdl-options.json

