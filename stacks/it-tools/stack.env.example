# IT Tools – optional environment variables
#
# This stack works out of the box without any env vars. Use this file if you
# want to override timezone/locale or pass Node.js options. Copy to .env and
# adjust values as needed.

# Timezone and locale
TZ=America/Denver
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8

# Optional: Node.js runtime options (memory limits, etc.)
# Example: limit Node to 512MB RAM
# NODE_OPTIONS=--max-old-space-size=512

