# Shlink – URL shortener. Copy to stack.env and set required values.
# Docs: https://shlink.io/documentation  Env vars: https://shlink.io/documentation/environment-variables/

# Required: short domain hostname (no protocol). Must match Caddy hostname, e.g. short.yourdomain.com
DEFAULT_DOMAIN=

# Required: true when served behind HTTPS (Caddy). Set to false only for local HTTP testing.
IS_HTTPS_ENABLED=true

# Required: GeoLite2 license key for visit geolocation. Get a free key at https://www.maxmind.com/en/geolite2/signup
# Without it, geolocation is disabled but Shlink still works.
GEOLITE_LICENSE_KEY=

# Optional: API key created at first startup (admin). If empty, generate after first run: docker exec shlink shlink api-key:generate
# Generate a secure key: openssl rand -hex 32
# INITIAL_API_KEY=

# Optional: number of proxies in front. Needed so visitor IP is correct. Use 1 for Caddy only; 2 for Caddy + Cloudflare Tunnel.
# TRUSTED_PROXIES=2

# Optional: image override (default: shlinkio/shlink:stable)
# SHLINK_IMAGE=shlinkio/shlink:stable

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
