# ArchiSteamFarm – optional environment variables
#
# Copy to stack.env and adjust. ASF is configured mainly via files in the config volume
# (ASF.json, bot configs). See README for IPC (web UI) and Kestrel setup.

# Optional: run ASF as this UID (e.g. match host user for volume file ownership)
# ASF_UID=1000

# Timezone (logs and in-app times)
TZ=America/Denver
