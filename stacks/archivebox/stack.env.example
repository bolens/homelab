# ArchiveBox – copy to .env. Set admin credentials and search password, then adjust hostnames for Caddy.
#
# Docs: https://github.com/ArchiveBox/ArchiveBox/wiki/Docker#docker-compose

# Required: initial admin user (created on first run)
# Use a strong random admin password, for example:
#   openssl rand -base64 32
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Required: password used by the Sonic full-text search backend.
# This must match across archivebox, archivebox_scheduler, and sonic.
# Use a strong random value here, for example:
#   openssl rand -hex 24
SEARCH_BACKEND_PASSWORD=

# Recommended: allowed hostnames for the web UI (comma-separated list).
# Set to the hostnames you use in Caddy, e.g.:
#   archivebox.home,archivebox.local,archivebox.yourdomain.com
# ALLOWED_HOSTS=archivebox.home,archivebox.local,archivebox.yourdomain.com

# Recommended: CSRF trusted origins (full URLs including scheme) for login/API.
# Example:
#   https://archivebox.home,https://archivebox.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://archivebox.home,https://archivebox.yourdomain.com

# Optional: control what anonymous users can see when the stack is exposed publicly.
# PUBLIC_INDEX=False
# PUBLIC_SNAPSHOTS=False
# PUBLIC_ADD_VIEW=False

# Timezone and locale
TZ=America/Denver
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8

