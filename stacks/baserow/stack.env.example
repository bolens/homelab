# Baserow – self-hosted database/spreadsheet
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs: https://baserow.io/docs/

# -----------------------------------------------------------------------------
# Required (when behind Caddy)
# -----------------------------------------------------------------------------

# Public URL where Baserow is reached (must match Caddy hostname).
# Example: https://baserow.yourdomain.com
BASEROW_PUBLIC_URL=https://baserow.yourdomain.com

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
