# Privotron – optional environment variables
#
# Privotron itself does not require env vars for basic use. This template
# exists so the stack has a consistent .env entry point.
#
# Copy to stack.env if you want to pin a specific Privotron version.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: use pre-built image from Harbor (skip local build)
# PRIVOTRON_IMAGE=harbor.yourdomain.com/homelab/privotron:latest

# Optional: build from a specific branch/tag instead of main (used at build time)
# PRIVOTRON_VERSION=main

