# Dozzle – Docker log viewer. Copy to stack.env and adjust as needed.
# Docs: https://dozzle.dev/

# Host port for Dozzle (container listens on 8080). Default 8082 avoids conflict with it-tools.
DOZZLE_HOST_PORT=8082

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Auth: set to "simple" when using file-based auth (users.yaml in dozzle_config volume). Omit or leave empty for no auth.
# DOZZLE_AUTH_PROVIDER=simple
