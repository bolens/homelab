# Naisho – copy to .env and set SECRET_KEY_BASE.
# https://github.com/nshki/naisho
#
# Generate SECRET_KEY_BASE: openssl rand -hex 64
#
# SMTP is configured per-request in the Naisho UI (when sending deletion emails).
# Use your own SMTP server or the smtp-relay stack (e.g. smtp-relay:587 on the monitor network).

# Required: Rails secret for signed/encrypted cookies and sessions.
SECRET_KEY_BASE=

# Optional: timezone
# TZ=America/Denver

# Optional: Rails log level (debug, info, warn, error)
# RAILS_LOG_LEVEL=info
