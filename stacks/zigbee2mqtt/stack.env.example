# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# MQTT broker settings (match your Mosquitto configuration)
ZIGBEE2MQTT_CONFIG_MQTT_SERVER=mqtt://mosquitto:1883
# Optional authentication:
# ZIGBEE2MQTT_CONFIG_MQTT_USER=zigbee2mqtt
# ZIGBEE2MQTT_CONFIG_MQTT_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

