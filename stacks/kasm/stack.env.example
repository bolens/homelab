# Kasm Workspaces – copy to stack.env and adjust as needed.
# Docs: https://docs.kasmweb.com/ | https://docs.linuxserver.io/images/docker-kasm/

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: Docker Hub credentials for pulling private workspace images.
# Leave empty if not using private images.
# DOCKER_HUB_USERNAME=
# DOCKER_HUB_PASSWORD=

# Optional: MTU for the internal Docker daemon (default 1500).
# DOCKER_MTU=1500
