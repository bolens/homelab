# Woodpecker CI – lightweight CI/CD server and agent
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://woodpecker-ci.org/
# - Docs: https://woodpecker-ci.org/docs/

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

WOODPECKER_DB_NAME=woodpecker
WOODPECKER_DB_USER=woodpecker
# Generate with: openssl rand -base64 24
WOODPECKER_DB_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Gitea integration
# -----------------------------------------------------------------------------

# URL of your Gitea instance (public URL behind Caddy).
# Example: https://gitea.yourdomain.com
WOODPECKER_GITEA_URL=https://gitea.yourdomain.com

# OAuth client ID/secret from Gitea (created as an OAuth2 app).
WOODPECKER_GITEA_CLIENT=REPLACE_WITH_GITEA_CLIENT_ID
WOODPECKER_GITEA_SECRET=REPLACE_WITH_GITEA_CLIENT_SECRET

# Allow self-service repo activation / login.
WOODPECKER_OPEN=false

# -----------------------------------------------------------------------------
# Agent / server
# -----------------------------------------------------------------------------

# Shared secret between server and agents (required).
# Generate with: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=REPLACE_WITH_GENERATED_AGENT_SECRET

# Server address used by agents to reach the server (inside Docker).
WOODPECKER_SERVER=woodpecker-server:9000

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

