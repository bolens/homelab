# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
PUID=1000
PGID=1000

# --- Server mode (see https://docs.linuxserver.io/images/docker-wireguard) ---
# Public IP or DNS name of this host (or 'auto' to detect)
SERVERURL=auto

# WireGuard port; forward this UDP port on your router
SERVERPORT=51820

# Peers: number (e.g. 3) or comma-separated names (e.g. laptop,phone,tablet)
PEERS=laptop,phone

# DNS for peer configs ('auto' = host DNS via CoreDNS)
PEERDNS=auto

# Internal VPN subnet (change only if it clashes)
INTERNAL_SUBNET=10.13.13.0

# Optional: IP ranges peers can reach (default all traffic)
# ALLOWEDIPS=0.0.0.0/0,::0/0

# Optional: keepalive for mobile clients
# PERSISTENTKEEPALIVE_PEERS=all
