# Gitea – self-hosted Git service
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://about.gitea.com/
# - Docs: https://docs.gitea.com/

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
# Generate with: openssl rand -base64 24
GITEA_DB_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Server URL and user
# -----------------------------------------------------------------------------

# Public URL for Gitea when running behind Caddy.
# Example: https://gitea.yourdomain.com
GITEA_ROOT_URL=https://gitea.yourdomain.com

# UID/GID for the Gitea process (for file ownership on bind mounts).
USER_UID=1000
USER_GID=1000

# Optional timezone
TZ=America/Denver

