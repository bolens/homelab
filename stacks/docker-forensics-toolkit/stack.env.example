# Docker Forensics Toolkit – optional environment variables
#
# Copy to stack.env if you want to override defaults.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: image from Harbor (default: harbor.yourdomain.com/homelab/docker-forensics-toolkit:latest)
#DOCKER_FORENSICS_TOOLKIT_IMAGE=harbor.yourdomain.com/homelab/docker-forensics-toolkit:latest

# Optional: set mountpoint for subsequent commands (avoid passing it every time)
# DOF_IMAGE_MOUNTPOINT=/tmp/forensic-mount-root
