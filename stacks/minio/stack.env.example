# MinIO – self-hosted S3-compatible object storage
# Copy to stack.env and customize. Do NOT commit real credentials.
#
# Docs:
# - MinIO: https://min.io/
# - Docker: https://docs.min.io/minio/container/

# Root user / password (S3 access key and secret).
# Generate strong values; never reuse credentials.
# Example:
#   MINIO_ROOT_USER:    openssl rand -hex 16
#   MINIO_ROOT_PASSWORD: openssl rand -base64 32
MINIO_ROOT_USER=REPLACE_WITH_ACCESS_KEY
MINIO_ROOT_PASSWORD=REPLACE_WITH_SECRET_KEY

# Optional: external URL used in links (e.g. when behind Caddy).
# Set to your public URL, such as:
#   MINIO_SERVER_URL=https://minio.yourdomain.com
MINIO_SERVER_URL=

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

