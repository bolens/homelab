# Slink – copy to .env. Set ORIGIN to your public URL (required for cookies and redirects).

# Required: application hostname (must match Caddy hostname, e.g. https://slink.home or https://slink.yourdomain.com)
ORIGIN=

# Optional: timezone (default America/Denver)
# TZ=America/Denver

# Optional: enable public API
# API_ENABLED=true

# Optional: require admin approval before new users can upload
# USER_APPROVAL_REQUIRED=true

# Optional: password policy (min length and bitmask for requirements; see Slink docs)
# USER_PASSWORD_MIN_LENGTH=8
# USER_PASSWORD_REQUIREMENTS=15

# Optional: max upload size (e.g. 15M; image limit is 50M)
# IMAGE_MAX_SIZE=15M

# Optional: strip EXIF metadata from uploads
# IMAGE_STRIP_EXIF_METADATA=true
# IMAGE_COMPRESSION_QUALITY=80

# Storage: local (default), smb, or s3 (see Slink docs for SMB/S3 env vars)
# STORAGE_PROVIDER=local

# Optional: create first admin on first run (remove after setup)
# Use a strong random admin password here, for example:
#   openssl rand -base64 32
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=YourSecurePassword123
