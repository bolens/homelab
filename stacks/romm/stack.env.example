# RomM – copy to stack.env and set required values.
# Docs: https://docs.romm.app/latest/Getting-Started/Environment-Variables/

# Required: auth secret (generate and store securely, do not commit).
#   openssl rand -hex 32
ROMM_AUTH_SECRET_KEY=

# Required: base URL used for links in emails and UI (must match Caddy hostname).
ROMM_BASE_URL=https://romm.yourdomain.com

# Required: MariaDB (used by romm-db and romm).
# Use strong random passwords, for example:
#   openssl rand -base64 24
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=romm
MARIADB_USER=romm
MARIADB_PASSWORD=

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: metadata provider API keys (see RomM docs for signup).
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=
# SCREENSCRAPER_USER=
# SCREENSCRAPER_PASSWORD=
# MOBYGAMES_API_KEY=
# STEAMGRIDDB_API_KEY=
# RETROACHIEVEMENTS_API_KEY=
