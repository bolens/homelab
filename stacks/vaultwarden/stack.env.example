# Vaultwarden – copy to stack.env. Set DOMAIN if using Caddy/reverse proxy.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Required when behind reverse proxy (HTTPS). Vaultwarden needs this for attachments and WebSocket.
# DOMAIN=https://vault.yourdomain.com

# Allow new signups. Set to false after creating your account.
SIGNUPS_ALLOWED=false

# Optional: enable WebSocket for live sync (default true when using reverse proxy with DOMAIN set).
# WEBSOCKET_ENABLED=true

# Optional: admin panel token (generate with: openssl rand -base64 48). Enables /admin.
# ADMIN_TOKEN=
