# SMTP relay – central outbound SMTP for your stacks.
# This container is a "null client" relay: apps send mail to it, and it delivers via
# your real mail provider (SES, Mailgun, Gmail, SMTP relay from your ISP, etc.).
# Image docs: https://github.com/bokysan/docker-postfix

# Required: domain(s) your apps use in From: addresses.
# Comma-separated list; messages from other domains are rejected.
# Example: yourdomain.com,example.com
ALLOWED_SENDER_DOMAINS=yourdomain.com

# Required: upstream SMTP provider to relay through.
# Format: host:port, e.g. smtp.sendgrid.net:587 or email-smtp.us-west-2.amazonaws.com:587
RELAYHOST=

# Optional: credentials for RELAYHOST (if your provider requires login).
# Common with SES / Mailgun / SMTP relays.
# RELAYHOST_USERNAME=
# RELAYHOST_PASSWORD=

# Optional: timezone
# TZ=America/Denver

# Optional: override hostname advertised in SMTP banner (EHLO/HELO).
# Defaults to container hostname; setting it to your public SMTP name is recommended.
# POSTFIX_myhostname=smtp.yourdomain.com

# Optional: message size limit in bytes (0 = unlimited; provider may still enforce a cap).
# POSTFIX_message_size_limit=0

