# Mylar3 – copy to stack.env. Set PUID/PGID to match host if using bind-mounted comics/downloads.
# Docs: https://docs.linuxserver.io/images/docker-mylar3

# Optional: user/group for file ownership (default 1000)
# PUID=1000
# PGID=1000

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
