# OWASP Dependency-Track – copy to .env and set required values.
# Docs: https://docs.dependencytrack.org/getting-started/configuration/

# Required: URL the browser uses to reach the API (see README for path vs subdomain).
# Examples: https://dtrack.home/api  or  https://api.dtrack.home
API_BASE_URL=https://dtrack.home/api

# Postgres (used by API server). Use a strong random password for POSTGRES_PASSWORD, e.g.:
#   openssl rand -hex 32
POSTGRES_DB=dtrack
POSTGRES_USER=dtrack
POSTGRES_PASSWORD=

# Optional
TZ=America/Denver
