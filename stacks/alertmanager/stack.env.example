# Optional: path to alertmanager.yml (required when deploying from Portainer; use absolute path).
# Example: /home/youruser/.config/alertmanager/alertmanager.yml
# ALERTMANAGER_CONFIG_PATH=/home/youruser/.config/alertmanager/alertmanager.yml

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: override Alertmanager web listen address/port if you change defaults.
# ALERTMANAGER_WEB_LISTEN_ADDRESS=:9093

