# Joplin Server – sync backend for Joplin clients
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Project: https://joplinapp.org/
# - Server: https://joplinapp.org/help/server/

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

POSTGRES_DB=joplin
POSTGRES_USER=joplin
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# App URL and settings
# -----------------------------------------------------------------------------

# Public base URL where Joplin clients reach the server (behind Caddy).
# Example: https://joplin.yourdomain.com
APP_BASE_URL=https://joplin.yourdomain.com

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

