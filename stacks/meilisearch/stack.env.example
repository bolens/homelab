# Meilisearch – search engine
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs: https://www.meilisearch.com/docs/

# -----------------------------------------------------------------------------
# Recommended when exposed (e.g. via Caddy)
# -----------------------------------------------------------------------------

# Required for production; protects API. Generate with: openssl rand -hex 32
MEILI_MASTER_KEY=

# development | production
MEILI_ENV=development

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
