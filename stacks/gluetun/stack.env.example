# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# --- Gluetun VPN (required) ---
# See https://gluetun.com/configuration/ and https://github.com/qdm12/gluetun-wiki
# Provider examples: mullvad, protonvpn, nordvpn, pia, custom, …
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard

# --- Provider-specific (examples) ---
# For OpenVPN providers:
# OPENVPN_USER=your-username
# OPENVPN_PASSWORD=REPLACE_WITH_VPN_PASSWORD

# For custom WireGuard (VPN_SERVICE_PROVIDER=custom):
# WIREGUARD_PRIVATE_KEY=REPLACE_WITH_YOUR_PRIVATE_KEY
# WIREGUARD_PUBLIC_KEY=REPLACE_WITH_SERVER_PUBLIC_KEY
# WIREGUARD_ENDPOINT_IP=1.2.3.4
# WIREGUARD_ENDPOINT_PORT=51820
# WIREGUARD_ADDRESSES=10.64.x.x/32
# WIREGUARD_PRESHARED_KEY=

# Optional: allow VPN-routed containers to reach specific LAN subnets
# FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
