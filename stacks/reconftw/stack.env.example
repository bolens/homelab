# ReconFTW – optional environment variables
#
# Copy to stack.env if you want to override defaults.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Config and output paths (default: ~/.config/reconftw/reconftw.cfg and ~/.config/reconftw/Recon)
# Set to absolute paths when deploying from Portainer (e.g. /home/user/.config/reconftw/reconftw.cfg)
# RECONFTW_CONFIG_PATH=/home/user/.config/reconftw/reconftw.cfg
# RECONFTW_RECON_PATH=/home/user/.config/reconftw/Recon

# Optional: HTTP(S) proxy settings if you route ReconFTW traffic
# through Caddy (forward proxy) or another proxy / VPN.
# When using Caddy: enable the forward_proxy block in Caddyfile (requires
# Caddy built with forwardproxy plugin) and expose port 3128.
# HTTP_PROXY=http://caddy:3128
# HTTPS_PROXY=http://caddy:3128

