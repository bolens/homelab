# ReconFTW – optional environment variables
#
# Copy to stack.env if you want to override defaults.

# Optional: timezone (for logs)
# TZ=America/Denver

# Optional: HTTP(S) proxy settings if you route ReconFTW traffic
# through a proxy / VPN. Uncomment and set as needed.
# HTTP_PROXY=http://proxy.internal:3128
# HTTPS_PROXY=http://proxy.internal:3128

