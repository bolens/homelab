# OWASP Threat Dragon – copy to stack.env and set required values.
# Docs: https://www.threatdragon.com/docs/configure/configure.html

# Required: 32-character hex key for session signing (e.g. openssl rand -hex 16)
SESSION_SIGNING_KEY=

# Optional: GitHub OAuth (for saving/loading models from GitHub repos).
# Create OAuth App: GitHub → Settings → Developer settings → OAuth Apps.
# Callback URL: https://threatdragon.home/oauth/github (use your Caddy hostname).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_SCOPE=repo

# Optional: Bitbucket / GitLab – see https://www.threatdragon.com/docs/configure/

# Optional
# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
NODE_ENV=production
