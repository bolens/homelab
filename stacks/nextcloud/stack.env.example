# Nextcloud – personal cloud storage, calendar, contacts
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Nextcloud: https://nextcloud.com/
# - Admin manual: https://docs.nextcloud.com/server/latest/admin_manual/

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Nextcloud admin and host
# -----------------------------------------------------------------------------

# Initial admin account created on first run.
NEXTCLOUD_ADMIN_USER=admin
# Generate with: openssl rand -base64 32
NEXTCLOUD_ADMIN_PASSWORD=REPLACE_WITH_GENERATED_ADMIN_PASSWORD

# Comma-separated list of trusted hostnames. Must include your Caddy URL.
# Example: nextcloud.yourdomain.com
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.yourdomain.com

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

