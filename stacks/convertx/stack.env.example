# ConvertX – copy to .env and set at least JWT_SECRET.
# Generate: openssl rand -base64 32  (or leave unset to use randomUUID() – not recommended for production)

# Recommended: long secret for signing JWT (required for stable sessions across restarts)
JWT_SECRET=

# Optional: timezone (default America/Denver)
# TZ=America/Denver

# Optional: allow new user registration. Set false after creating your first account.
# ACCOUNT_REGISTRATION=false

# Optional: allow HTTP (non-HTTPS). Only set true for local/dev; behind Caddy with HTTPS leave false.
# HTTP_ALLOWED=false

# Optional: allow unauthenticated use (no login). Only for local/dev.
# ALLOW_UNAUTHENTICATED=false

# Optional: delete converted files older than N hours (cron every N hours). Set 0 to disable.
# AUTO_DELETE_EVERY_N_HOURS=24

# Optional: web root path, e.g. "/convert" to serve at example.com/convert/
# WEBROOT=

# Optional: hide the history page
# HIDE_HISTORY=false

# Optional: date/locale language (BCP 47 tag, e.g. en, de, fr)
# LANGUAGE=en

# Optional: max concurrent conversion processes. 0 = unlimited.
# MAX_CONVERT_PROCESS=0

# Optional: FFmpeg input args (e.g. -hwaccel vaapi for GPU). See ConvertX docs.
# FFMPEG_ARGS=
# FFMPEG_OUTPUT_ARGS=
