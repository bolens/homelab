# SimpleLogin – copy to stack.env and set required values.
# Full reference: https://github.com/simple-login/app/blob/master/example.env
#
# First: generate DKIM key and put private key at ./data/dkim.key (see README).
# Generate FLASK_SECRET: openssl rand -hex 32

# Required: full URL users use to reach the app (no trailing slash).
# Local: https://simplelogin.home   Public: https://simplelogin.yourdomain.com
URL=https://simplelogin.home

# Domain used for alias addresses (e.g. alias@EMAIL_DOMAIN). MX must point to your mail receiver.
EMAIL_DOMAIN=yourdomain.com

# MX record value for EMAIL_DOMAIN (hostname that receives mail for aliases).
# Format: [(priority, "hostname.")]  e.g. [(10, "mail.yourdomain.com.")]
EMAIL_SERVERS_WITH_PRIORITY=[(10, "mail.yourdomain.com.")]

# Required: from address for transactional emails (signup, support).
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_NAME=SimpleLogin

# Required: generate with  openssl rand -hex 32
FLASK_SECRET=

# Postgres (used by DB_URI in compose)
POSTGRES_USER=simplelogin
POSTGRES_PASSWORD=
POSTGRES_DB=simplelogin

# Optional: outbound SMTP. If set, app sends mail via this host (e.g. your smtp-relay stack).
# Leave empty to use same server that receives mail (see README for receiving setup).
# Example (same host, monitor network): smtp-relay
# Example (port 587): smtp-relay:587  (SimpleLogin may use POSTFIX_PORT for this)
POSTFIX_SERVER=
POSTFIX_PORT=25

# Optional: admin email for stats/alerts
# ADMIN_EMAIL=admin@yourdomain.com

# Optional: disable signups after creating accounts. 0 = allow, 1 = disable
# DISABLE_REGISTRATION=0

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: for local dev only – set to true to print emails instead of sending
# NOT_SEND_EMAIL=false

# Optional: allowed redirect domains (JSON list). Default []
# ALLOWED_REDIRECT_DOMAINS=[]
