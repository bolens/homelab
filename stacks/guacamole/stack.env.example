# Apache Guacamole – copy to stack.env and set required values.
# Run ./prepare-stack.sh to create stack.env and ~/.config/guacamole/guacamole.properties.
# Docs: https://guacamole.apache.org/doc/gug/

# Optional: override config directory (default: ~/.config/guacamole). Set to absolute path for Portainer.
# GUACAMOLE_CONFIG_PATH=/home/youruser/.config/guacamole

# Database settings (used by both Postgres and the Guacamole web app).
# Use a strong random password for POSTGRES_PASSWORD, for example:
#   openssl rand -hex 32
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole
POSTGRES_PASSWORD=

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

