# HedgeDoc – collaborative markdown editor
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://hedgedoc.org/
# - Docs: https://docs.hedgedoc.org/

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

POSTGRES_DB=hedgedoc
POSTGRES_USER=hedgedoc
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Host / domain
# -----------------------------------------------------------------------------

# Public domain where HedgeDoc is served (behind Caddy).
# Example: hedgedoc.yourdomain.com
CMD_DOMAIN=hedgedoc.yourdomain.com

# Optional timezone
TZ=America/Denver

