# Metagoofil – optional environment variables
#
# Copy to stack.env if you want to override defaults.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: data directory (default: ~/.config/metagoofil/data). For Portainer, use absolute path.
# METAGOOFIL_DATA_PATH=/home/youruser/.config/metagoofil/data

# Optional: pre-built image from Harbor (skip local build)
# METAGOOFIL_IMAGE=harbor.yourdomain.com/homelab/metagoofil:latest

# Optional: HTTP(S) proxy settings if you route Metagoofil traffic
# through Caddy (forward proxy) or another proxy / VPN.
# When using Caddy: enable the forward_proxy block in Caddyfile (requires
# Caddy built with forwardproxy plugin) and expose port 3128.
# HTTP_PROXY=http://caddy:3128
# HTTPS_PROXY=http://caddy:3128
