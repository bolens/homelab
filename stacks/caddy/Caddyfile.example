# Caddy reverse proxy – runs on your Docker host.
# Copy to Caddyfile and replace yourdomain.com and email with your values.
# Local DNS (e.g. AdGuard): use .home / .local. Public: use your domain.
#
# Structure:
#   1. Local (.home / .local) – internal TLS for LAN
#   2. Public HTTPS (yourdomain.com) – Cloudflare DNS TLS
#   (If using Cloudflare Tunnel for HTTP, add auto_https disable_redirects in the global block and a :80 host-routing block.)
{
	email admin@example.com
}

# ═══════════════════════════════════════════════════════════════════════════════
# Optional: HTTP forward proxy for CLI tools (Blackbird, etc.)
# Requires Caddy built with: xcaddy build --with github.com/caddyserver/forwardproxy
# The default serfriz/caddy-cloudflare image does NOT include this plugin.
# Expose port 3128 in docker-compose (add "3128:3128" to ports) when using this.
# ═══════════════════════════════════════════════════════════════════════════════
# :3128 {
# 	forward_proxy
# }

# ═══════════════════════════════════════════════════════════════════════════════
# Local (.home / .local) – internal TLS
# ═══════════════════════════════════════════════════════════════════════════════

# Infrastructure (Portainer attaches to monitor network)
portainer.home, portainer.local {
	tls internal
	reverse_proxy https://portainer:9443 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Ssl on
		transport http {
			tls
			tls_insecure_skip_verify
		}
	}
}

kuma.home, kuma.local {
	tls internal
	reverse_proxy uptime-kuma:3001
}

adguard-home.home, adguard-home.local {
	tls internal
	reverse_proxy adguard-home:3000
}

# Tools
asf.home, asf.local {
	tls internal
	reverse_proxy asf:1242
}

it-tools.home, it-tools.local {
	tls internal
	reverse_proxy it-tools:80
}

convertx.home, convertx.local {
	tls internal
	reverse_proxy convertx:3000
}

crowdsec.home, crowdsec.local {
	tls internal
	handle / {
		header Content-Type text/plain
		respond "CrowdSec LAPI – use /metrics, /health, /v1/..." 200
	}
	handle {
		reverse_proxy crowdsec:8080
	}
}

dozzle.home, dozzle.local {
	tls internal
	reverse_proxy dozzle:8080
}

n8n.home, n8n.local {
	tls internal
	reverse_proxy n8n:5678
}

web-check.home, web-check.local {
	tls internal
	reverse_proxy web-check:3000
}

searx-ng.home, searx-ng.local {
	tls internal
	reverse_proxy searxng:8080
}

social-hunt.home, social-hunt.local {
	tls internal
	reverse_proxy social-hunt:8000
}

maigret.home, maigret.local {
