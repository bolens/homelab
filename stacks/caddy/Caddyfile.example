# Harbor proxy attaches to monitor network via docker-compose.override.yml
# Required for docker push/pull: X-Forwarded headers + disable buffering
# Allow large image pushes (no request body limit)
harbor.home, harbor.local {
	tls internal
	request_body {
		max_size 0
	}
	reverse_proxy proxy:8080 {
		header_up X-Forwarded-Proto https
		flush_interval -1
		transport http {
			write_buffer 0
			read_buffer 0
		}
	}
}

privatebin.home, privatebin.local {
	tls internal
	reverse_proxy privatebin:8080
}

pwpush.home, pwpush.local {
	tls internal
