}

kasm.home, kasm.local {
	tls internal
	reverse_proxy https://kasm:443 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
		flush_interval -1
		transport http {
			tls_insecure_skip_verify
		}
	}
}

kasm-setup.home, kasm-setup.local {
	tls internal
	reverse_proxy https://kasm:3000 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
