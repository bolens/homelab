# MinIO: path routing so console (9001) and S3 API (9000) share same host; /console/ for auth
minio.yourdomain.com {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	redir /console /console/
	handle_path /console* {
		reverse_proxy minio:9001 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
		}
	}
	handle {
		reverse_proxy minio:9000 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
		}
	}
	request_body {
		max_size 0
	}
}

