# ntfy – push notifications
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs: https://docs.ntfy.sh/

# -----------------------------------------------------------------------------
# Recommended when behind Caddy
# -----------------------------------------------------------------------------

# Public URL where ntfy is reached (must match Caddy hostname).
# Example: https://ntfy.yourdomain.com
NTFY_BASE_URL=https://ntfy.yourdomain.com

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
