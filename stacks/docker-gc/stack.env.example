# docker-gc – Docker containers & images garbage collector
# Copy to stack.env and adjust. By default this runs in DRY RUN mode
# so you can see what would be deleted without actually removing anything.
#
# Example usage (from this stack directory):
#   docker compose up docker-gc
# or:
#   docker compose run --rm docker-gc
#
# For scheduled runs, create a cron job or systemd timer on the host that
# calls one of the commands above.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: image from Harbor (default: harbor.yourdomain.com/homelab/docker-gc:latest)
#DOCKER_GC_IMAGE=harbor.yourdomain.com/homelab/docker-gc:latest

# Global dry-run switch (applies to both containers and images)
# Set to "true" to only log what would be removed.
DRY_RUN=true

# Fine-grained dry-run flags (override DRY_RUN for each resource type)
#DRY_RUN_CONTAINERS=true
#DRY_RUN_IMAGES=true
#DRY_RUN_VOLUMES=true
#DRY_RUN_NETWORKS=true
#DRY_RUN_BUILD_CACHE=true

# Exclude specific images from garbage collection (space-separated list)
# Examples:
#EXCLUDE_IMAGES="alpine busybox"

# Exclude specific containers from garbage collection (space-separated list)
# CLI tools run on-demand and may be stopped for long periods; exclude them so
# docker-gc does not remove them. Also exclude services you may pause (e.g. librechat).
#EXCLUDE_CONTAINERS="portainer watchtower acquire blackbird docker-forensics-toolkit ghunt librechat metagoofil onionscan plaso privotron reconftw restic sublist3r theharvester torbot"

# Exclude specific volumes from garbage collection (space-separated list)
# Only used when REMOVE_VOLUMES=true
#EXCLUDE_VOLUMES="my_volume data_backup"

# Grace period before resources are eligible for removal (overall default)
# Use GRACE_PERIOD (human-readable) or GRACE_PERIOD_SECONDS (integer)
# Examples: GRACE_PERIOD=24h, 1d, 48h
#GRACE_PERIOD=24h
#GRACE_PERIOD_SECONDS=86400

# Per-resource grace periods (override overall; same format as GRACE_PERIOD)
#GRACE_PERIOD_CONTAINERS=24h
#GRACE_PERIOD_IMAGES=48h
#GRACE_PERIOD_VOLUMES=72h
#GRACE_PERIOD_NETWORKS=24h
#GRACE_PERIOD_BUILD_CACHE=168h

# Minimum image tags to keep per repository (default: 0)
#MINIMUM_IMAGES_TO_SAVE=1

# Removal behavior (true/false)
#REMOVE_ASSOCIATED_VOLUME=true
#FORCE_CONTAINER_REMOVAL=false
#FORCE_IMAGE_REMOVAL=false
#EXCLUDE_DEAD=false
#REMOVE_VOLUMES=false

# When REMOVE_VOLUMES=true: only remove volumes with this driver (default: local)
#VOLUME_DELETE_ONLY_DRIVER=local

# Network prune: remove unused networks older than grace period (default: false)
#REMOVE_NETWORKS=false
#EXCLUDE_NETWORKS="monitor"
#GRACE_PERIOD_NETWORKS=

# Build cache prune: remove build cache older than grace period (default: false)
#REMOVE_BUILD_CACHE=false
#GRACE_PERIOD_BUILD_CACHE=

# Log to syslog instead of stdout
#LOG_TO_SYSLOG=false

