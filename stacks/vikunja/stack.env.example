# Vikunja – tasks and lists
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs: https://vikunja.io/docs/

# -----------------------------------------------------------------------------
# Required (when behind Caddy)
# -----------------------------------------------------------------------------

# Public URL where Vikunja is reached (must match Caddy hostname). Include trailing slash.
# Example: https://vikunja.yourdomain.com/
VIKUNJA_SERVICE_PUBLICURL=https://vikunja.yourdomain.com/

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
# sqlite | mysql | postgres
VIKUNJA_DATABASE_TYPE=sqlite
# For SQLite (default path in container)
# VIKUNJA_DATABASE_PATH=/app/vikunja/vikunja.db
