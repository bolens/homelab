# Perplexica Configuration
# Copy this file to .env and customize as needed

# SearxNG Configuration
# Leave empty to use bundled SearxNG (recommended)
# If you have an external SearxNG instance, set its URL here
# Example: http://searxng:8080 or http://host.docker.internal:8080
SEARXNG_API_URL=

# Ollama Configuration
# Set to http://ollama:11434 if Ollama is on the same Docker network
# Set to http://host.docker.internal:11434 if Ollama is on host
OLLAMA_BASE_URL=http://host.docker.internal:11434

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
