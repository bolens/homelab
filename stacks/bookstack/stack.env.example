# BookStack – wiki and documentation
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs: https://www.bookstackapp.com/docs/

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Public URL where BookStack is reached (must match Caddy hostname).
# Example: https://bookstack.yourdomain.com
APP_URL=https://bookstack.yourdomain.com

# MariaDB (and BookStack DB connection)
# Generate with: openssl rand -base64 24
# Use the same value for MYSQL_PASSWORD and DB_PASSWORD.
MYSQL_ROOT_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
MYSQL_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
DB_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
# For bind-mounted storage: set to host user/group (e.g. id -u / id -g)
PUID=1000
PGID=1000
