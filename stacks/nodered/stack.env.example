# Node-RED – low-code flow-based programming for wiring together hardware, APIs, and online services.
# Docs: https://nodered.org/docs/
#
# Copy to .env and adjust as needed. These values are safe defaults; you can also
# set them via Portainer when deploying the stack.

# Timezone and locale
TZ=America/Denver
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8

# Optional: Node.js runtime options (memory limits, etc.)
# Example to cap memory to 512MB:
# NODE_OPTIONS=--max-old-space-size=512

