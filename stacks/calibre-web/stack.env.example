# Calibre-Web – copy to stack.env. Set PUID/PGID to match host if using bind-mounted library.
# Docs: https://docs.linuxserver.io/images/docker-calibre-web

# Optional: user/group for file ownership (default 1000)
# PUID=1000
# PGID=1000

# Optional: timezone
# TZ=America/Denver

# Optional: cookie encryption (recommended if exposed). Generate with: openssl rand -hex 32
# SECRET_KEY=

# Optional (x86-64 only): enable ebook conversion in the app
# DOCKER_MODS=linuxserver/mods:universal-calibre

# Optional: for Google OAuth in Calibre-Web
# OAUTHLIB_RELAX_TOKEN_SCOPE=1
