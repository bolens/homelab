# Social-Hunt – copy to .env and set at least ADMIN_TOKEN.
# Full env reference: https://github.com/AfterPacket/Social-Hunt#environment-variables

# Required: dashboard login and protected actions. Generate: openssl rand -hex 32
ADMIN_TOKEN=

# Required when behind Caddy: base URL users use (no trailing slash).
# Used for reverse-image search links. Local: https://social-hunt.home  Public: https://social-hunt.yourdomain.com
SOCIAL_HUNT_PUBLIC_URL=https://social-hunt.home

# Optional: allow setting admin token in UI when none is configured (0 = off, 1 = on). Disable after first setup.
# SOCIAL_HUNT_ENABLE_TOKEN_BOOTSTRAP=0

# Optional: allow uploading YAML/Python plugins via dashboard (0 = off, 1 = on)
# SOCIAL_HUNT_ENABLE_WEB_PLUGIN_UPLOAD=0

# Optional: token for plugin upload / protected actions (can match ADMIN_TOKEN)
# SOCIAL_HUNT_PLUGIN_TOKEN=

# Optional: Tor SOCKS for .onion (e.g. socks5h://127.0.0.1:9050). Clearnet uses direct connection.
# SOCIAL_HUNT_PROXY=

# Optional: HTTP/SOCKS proxy for clearnet (e.g. if your IP is blocked by BreachVIP)
# SOCIAL_HUNT_CLEARNET_PROXY=

# Optional: hCaptcha for login (get keys at hcaptcha.com)
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET=

# Optional: demo mode – censor sensitive fields (0 = off, 1 = on)
# SOCIAL_HUNT_DEMO_MODE=0

# Optional: timezone
# TZ=America/Denver

# API keys (HIBP, Snusbase, LeakCheck, Replicate, etc.) can be added in the dashboard: Settings → Add API
