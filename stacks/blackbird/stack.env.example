# Blackbird – optional environment variables
#
# Copy to stack.env if you want to override defaults.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: image from Harbor (default: harbor.yourdomain.com/homelab/blackbird:latest)
#BLACKBIRD_IMAGE=harbor.yourdomain.com/homelab/blackbird:latest

# Optional: HTTP(S) proxy settings if you route Blackbird traffic
# through Caddy (forward proxy) or another proxy / VPN.
# When using Caddy: enable the forward_proxy block in Caddyfile (requires
# Caddy built with forwardproxy plugin) and expose port 3128.
# HTTP_PROXY=http://caddy:3128
# HTTPS_PROXY=http://caddy:3128

