# YOURLS – Your Own URL Shortener. Copy to stack.env and set required values.
# Docs: https://docs.yourls.org/

# Optional: image (default: yourls:1.10.3-apache). Override only if using a custom or private registry image.
# YOURLS_IMAGE=yourls:1.10.3-apache

# Required: public URL of your shortener (must match Caddy hostname). Use bare domain so short links are https://urls.yourdomain.com/abc (vhost serves dashboard at /).
# Examples: https://urls.home, https://urls.yourdomain.com
YOURLS_SITE=

# Required: admin login for the web interface.
YOURLS_USER=
YOURLS_PASS=

# Required: random string for cookie auth. Generate: openssl rand -hex 32
YOURLS_COOKIEKEY=

# Required: MariaDB credentials (used by both app and DB container). Generate: openssl rand -base64 24 (use two runs for two different values)
YOURLS_DB_PASSWORD=
YOURLS_DB_ROOT_PASSWORD=

# Optional: DB name and user (defaults: yourls).
# YOURLS_DB_NAME=yourls
# YOURLS_DB_USER=yourls

# Optional: config directory containing vhost.conf and proxy-https-fix.php (default: ~/.config/yourls). Set to absolute path when using Portainer.
# YOURLS_CONFIG_DIR=/home/youruser/.config/yourls

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
