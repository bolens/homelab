# Outline – team knowledge base / wiki
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://www.getoutline.com/
# - Self-hosting: https://app.getoutline.com/share/6f0b6b4f-9d7c-4aa7-9e10-7c164cb1b2dd

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

POSTGRES_DB=outline
POSTGRES_USER=outline
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Core URLs and secrets
# -----------------------------------------------------------------------------

# Public URL where Outline is served (behind Caddy).
# Example: https://outline.yourdomain.com
URL=https://outline.yourdomain.com

# Strong 32+ byte secret for JWT/session encryption.
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# Secret used for internal utilities (webhooks, etc.).
# Generate with: openssl rand -hex 32
UTILS_SECRET=REPLACE_WITH_GENERATED_UTILS_SECRET

# -----------------------------------------------------------------------------
# S3 storage (MinIO or other S3-compatible)
# -----------------------------------------------------------------------------

# When using the MinIO stack, the internal endpoint is typically http://minio:9000
AWS_ACCESS_KEY_ID=REPLACE_WITH_MINIO_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_MINIO_SECRET_KEY
AWS_REGION=us-east-1

# Example (MinIO) bucket URL and name:
#   AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000/outline
#   AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_UPLOAD_BUCKET_URL=
AWS_S3_UPLOAD_BUCKET_NAME=

# Optional timezone
TZ=America/Denver

