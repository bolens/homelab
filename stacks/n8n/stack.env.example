# n8n – workflow automation. Copy to stack.env and set N8N_HOST + WEBHOOK_URL.
# Docs: https://docs.n8n.io/hosting/

# Required when behind Caddy: hostname and full webhook base URL (no trailing path).
# Examples: https://n8n.home  https://n8n.yourdomain.com
N8N_HOST=
WEBHOOK_URL=

# Protocol when behind HTTPS reverse proxy (default https).
# N8N_PROTOCOL=https

# Optional: set a fixed encryption key so credentials survive volume recreation.
# Generate with: openssl rand -hex 32
# N8N_ENCRYPTION_KEY=

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
