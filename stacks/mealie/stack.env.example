# Mealie – copy to .env. Set BASE_URL if using Caddy/reverse proxy.

# -----------------------------------------------------------------------------
# Locale & timezone (see documents/ENV-VARS.md)
# -----------------------------------------------------------------------------
TZ=America/Denver

# Required when behind reverse proxy (HTTPS). Use your full Mealie URL.
# BASE_URL=https://mealie.yourdomain.com

# Allow new user signups. Set to false after creating your account.
ALLOW_SIGNUP=false

# Database: sqlite (default) or postgres. For postgres, add POSTGRES_* vars,
# a postgres service, and use a strong random password for POSTGRES_PASSWORD, e.g.:
#   openssl rand -hex 32
DB_ENGINE=sqlite
