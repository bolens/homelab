# Prometheus – optional environment variables
#
# Prometheus runs fine with defaults. Use this file if you want to standardize
# timezone/locale or override the config file path.

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: override path to prometheus.yml (must be the full path to the FILE, not a directory).
# Example: /home/youruser/.config/prometheus/prometheus.yml or /opt/prometheus/prometheus.yml
# PROMETHEUS_CONFIG_PATH=/opt/prometheus/prometheus.yml

# Optional: override path to the directory containing alerts.yml (default: ~/.config/prometheus/rules).
# Required when deploying from Portainer; use the absolute path to the rules directory.
# PROMETHEUS_RULES_PATH=/home/youruser/.config/prometheus/rules

# Optional: TSDB retention (default: 30d). Examples: 15d, 30d, 90d.
# PROMETHEUS_RETENTION_TIME=30d

