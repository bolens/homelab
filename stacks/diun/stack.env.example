# Diun – Docker image update notifier
# Copy to stack.env and set at least one notifier so you receive alerts.

# Telegram (create bot via @BotFather, then start a chat and get your chat ID)
DIUN_NOTIF_TELEGRAM_TOKEN=
DIUN_NOTIF_TELEGRAM_CHATIDS=

# Optional: Discord webhook (Server → Integrations → Webhooks)
# DIUN_NOTIF_DISCORD_WEBHOOKURL=https://discord.com/api/webhooks/...

# Optional: only watch containers with label diun.enable=true (default: watch all)
# DIUN_PROVIDERS_DOCKER_WATCHBYDEFAULT=false
# Then add to each stack you want to watch: labels: - "diun.enable=true"

# Optional: email notifier (use shared Postfix relay – stacks/postfix, SHARED-RESOURCES.md)
# DIUN_NOTIF_MAIL_HOST=smtp-relay
# DIUN_NOTIF_MAIL_PORT=587
# DIUN_NOTIF_MAIL_SSL=false
# DIUN_NOTIF_MAIL_USERNAME=
# DIUN_NOTIF_MAIL_PASSWORD=
# DIUN_NOTIF_MAIL_FROM=diun@yourdomain.com
# DIUN_NOTIF_MAIL_TO=you@yourdomain.com

# Optional: Email notifier (shared Postfix relay – stacks/postfix)
# DIUN_NOTIF_MAIL_HOST=smtp-relay
# DIUN_NOTIF_MAIL_PORT=587
# DIUN_NOTIF_MAIL_FROM=diun@yourdomain.com
# DIUN_NOTIF_MAIL_TO=you@yourdomain.com

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)
