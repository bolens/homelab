# Watchtower – image update automation
#
# The stack sets sensible defaults in docker-compose.yml. Use this file if you
# want to tweak poll interval, label behavior, or timezone. Copy to .env and
# adjust values as needed; then update the compose to reference ${VAR} if you
# prefer env-driven configuration.

# Timezone and locale
TZ=America/Denver
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8

# Check for updates every N seconds (default: 86400 = 24h)
WATCHTOWER_POLL_INTERVAL=86400

# Remove old images after updating (saves disk space)
WATCHTOWER_CLEANUP=true

# Only update containers with label com.centurylinklabs.watchtower.enable=true
# Set to "true" to enable label filtering; "false" = update all containers
WATCHTOWER_LABEL_ENABLE=false

