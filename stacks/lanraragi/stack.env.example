# Lanraragi – copy to stack.env. Optional: TZ, LRR_UID, LRR_GID for permissions.
# Docs: https://sugoi.gitbook.io/lanraragi/installing-lanraragi/docker

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: user/group (default 9001). Use host UID/GID if bind-mounting content with permission issues.
# LRR_UID=1000
# LRR_GID=1000

# Optional: disable auto permission fix on startup (faster for large libraries)
# LRR_AUTOFIX_PERMISSIONS=-1
