# Optional: set if you access Grafana at a different URL (e.g. behind Caddy with public domain).
# GF_SERVER_ROOT_URL=https://grafana.yourdomain.com

# Set to false so Grafana creates default admin (admin/admin) on first start. If true, no default admin; use signup or CLI to create first user.
# GF_SECURITY_DISABLE_INITIAL_ADMIN_CREATION=false

# Set to true temporarily to show sign-up and create first user when no admin exists; set back to false after.
# GF_USERS_ALLOW_SIGN_UP=false

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Optional: path to datasources.yml (required when deploying from Portainer; use absolute path).
# GRAFANA_DATASOURCES_PATH=/home/youruser/.config/grafana/datasources.yml

# Optional: path to dashboard provisioning dir (must contain default.yaml and json/ subdir; see README).
# GRAFANA_DASHBOARDS_PATH=/home/youruser/.config/grafana/provisioning_dashboards
