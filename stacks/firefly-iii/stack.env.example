# Firefly III – personal finance manager
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Website: https://www.firefly-iii.org/
# - Docker: https://hub.docker.com/r/fireflyiii/core

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

DB_DATABASE=firefly
DB_USERNAME=firefly
# Generate with: openssl rand -base64 24
DB_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# App URL and key
# -----------------------------------------------------------------------------

# Public URL where Firefly III is served (behind Caddy).
# Example: https://firefly.yourdomain.com
APP_URL=https://firefly.yourdomain.com

# APP_KEY – 32-character Laravel key.
# Generate with: docker run --rm fireflyiii/core php artisan key:generate --show
APP_KEY=base64:REPLACE_WITH_GENERATED_APP_KEY

# Optional timezone
TZ=America/Denver

