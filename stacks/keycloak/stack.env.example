# Keycloak – identity provider (IdP) and SSO server
# Copy to stack.env and customize. Do NOT commit real secrets.
#
# Docs:
# - Keycloak: https://www.keycloak.org/
# - Docker: https://www.keycloak.org/server/containers

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres credentials for Keycloak's database.
# Generate a strong password, e.g.: openssl rand -base64 24
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_DB_PASSWORD

# -----------------------------------------------------------------------------
# Keycloak admin account
# -----------------------------------------------------------------------------

# Initial admin user for the Keycloak admin console.
KEYCLOAK_ADMIN=admin
# Generate a strong password, e.g.: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_GENERATED_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Hostname / URLs
# -----------------------------------------------------------------------------

# Public base URL for Keycloak when running behind Caddy.
# Example: https://keycloak.yourdomain.com
KC_HOSTNAME=https://keycloak.yourdomain.com

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

