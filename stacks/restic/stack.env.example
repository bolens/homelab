# Restic backup (cron) – copy to stack.env and customize.
# This stack is CLI/cron-only (no web UI). It runs restic backups on a schedule.
# Typical use: back up important host paths to MinIO (S3-compatible) or another S3 backend.
#
# Docs:
# - Restic: https://restic.readthedocs.io/
# - mazzolino/restic image: https://github.com/mazzolino/docker-restic

# -----------------------------------------------------------------------------
# Repository and credentials
# -----------------------------------------------------------------------------

# S3 repository URL; example when using the MinIO stack in this repo:
#   RESTIC_REPOSITORY=s3:http://minio:9000/restic
RESTIC_REPOSITORY=

# Encryption password for the repository (required).
# Generate with: openssl rand -base64 32
RESTIC_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# S3 credentials for the backup target (e.g. MinIO access key / secret key).
AWS_ACCESS_KEY_ID=REPLACE_WITH_MINIO_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_MINIO_SECRET_KEY

# -----------------------------------------------------------------------------
# Schedule and options
# -----------------------------------------------------------------------------

# Cron schedule for automatic backups (container local time).
# Default here: daily at 03:00.
# Format: minute hour day-of-month month day-of-week
BACKUP_CRON=0 3 * * *

# TZ/locale: use shared.env (see documents/SHARED-RESOURCES.md)

# Additional restic options can be set via image-specific env vars; see:
# https://github.com/mazzolino/docker-restic

