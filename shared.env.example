# Shared environment (timezone & locale)
# Copy to shared.env in this directory and set your values. Do NOT commit shared.env.
#
# Use with:
# - CLI: from a stack dir: docker compose --env-file ../shared.env --env-file stack.env up -d
# - Portainer: add these variables to each stack's Environment (see documents/SHARED-RESOURCES.md)

TZ=America/Denver
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8
